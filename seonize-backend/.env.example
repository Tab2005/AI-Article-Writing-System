# Seonize Backend Environment Variables

# Database (use SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./seonize.db
# DATABASE_URL=postgresql://user:password@localhost:5432/seonize

# Cache (optional - leave empty to use in-memory cache)
REDIS_URL=

# CORS
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Google Search API
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# DataForSEO API
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
DATAFORSEO_USE_SANDBOX=false

# AI Provider Settings
AI_PROVIDER=gemini
GEMINI_API_KEY=
AI_MODEL=gemini-2.0-flash

# Zeabur AI (alternative)
ZEABUR_API_KEY=

# OpenAI (alternative)
OPENAI_API_KEY=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
