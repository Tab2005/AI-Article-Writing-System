# Seonize Backend Environment Variables

# Database (use SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./seonize.db
# DATABASE_URL=postgresql://user:password@localhost:5432/seonize

# Cache (optional - leave empty to use in-memory cache)
REDIS_URL=

# CORS
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Security
SECRET_KEY="your-super-secret-key-change-it-in-env"
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_PASSWORD=admin123

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
